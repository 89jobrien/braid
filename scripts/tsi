#!/usr/bin/env bash
#
# TSI - Test Session Interface
# Global command wrapper for Braid CLI operations
#
set -euo pipefail

# Find the braid project directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Handle both direct execution and symlinked global installation
if [[ -L "${BASH_SOURCE[0]}" ]]; then
    # If script is a symlink, resolve to original location
    REAL_SCRIPT="$(readlink "${BASH_SOURCE[0]}")"
    REAL_SCRIPT_DIR="$(cd "$(dirname "$REAL_SCRIPT")" && pwd)"
    BRAID_ROOT="$(dirname "$REAL_SCRIPT_DIR")"
else
    # Direct execution from scripts directory
    BRAID_ROOT="$(dirname "$SCRIPT_DIR")"
fi

# Default values
DEFAULT_MODEL="gpt-4o"
DEFAULT_PROVIDER=""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Usage function
usage() {
    cat << EOF
TSI - Test Session Interface

USAGE:
    tsi <command> [OPTIONS] [ARGS...]

COMMANDS:
    run <prompt>        Run a session with the given prompt
    doctor             Check environment health
    mcp                Start MCP server
    build              Build the braid workspace
    test               Run tests
    help               Show this help message

OPTIONS:
    --provider <name>   Provider to use (ollama, openai)
    --model <name>      Model name (default: $DEFAULT_MODEL)
    --verbose          Enable verbose output

EXAMPLES:
    tsi run "Hello, world!"
    tsi run --provider ollama --model llama3.2 "Write a function"
    tsi doctor
    tsi build
    tsi test

EOF
}

# Logging functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $*" >&2
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $*" >&2
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $*" >&2
}

# Check if we're in the right directory
check_braid_root() {
    if [[ ! -f "$BRAID_ROOT/Cargo.toml" ]] || [[ ! -d "$BRAID_ROOT/crates/braid-cli" ]]; then
        log_error "Could not find braid workspace at $BRAID_ROOT"
        log_error "Make sure this script is in the braid/scripts directory"
        exit 1
    fi
}

# Build the braid CLI if needed
ensure_braid_cli() {
    local binary_path="$BRAID_ROOT/target/release/braid-cli"
    
    if [[ ! -f "$binary_path" ]]; then
        log_info "Building braid CLI..."
        cd "$BRAID_ROOT"
        if ! uv run cargo build --release -p braid-cli; then
            log_error "Failed to build braid CLI"
            exit 1
        fi
        log_success "Built braid CLI"
    fi
}

# Run braid command
run_braid() {
    cd "$BRAID_ROOT"
    uv run cargo run -p braid-cli --release -- "$@"
}

# Parse command line arguments
parse_args() {
    local cmd=""
    local provider=""
    local model="$DEFAULT_MODEL"
    local verbose=false
    local args=()

    while [[ $# -gt 0 ]]; do
        case $1 in
            --provider)
                provider="$2"
                shift 2
                ;;
            --model)
                model="$2"
                shift 2
                ;;
            --verbose)
                verbose=true
                shift
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            run|doctor|mcp|build|test|help)
                if [[ -z "$cmd" ]]; then
                    cmd="$1"
                    shift
                else
                    args+=("$1")
                    shift
                fi
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done

    # Export parsed values
    TSI_CMD="$cmd"
    TSI_PROVIDER="$provider"
    TSI_MODEL="$model"
    TSI_VERBOSE="$verbose"
    TSI_ARGS=("${args[@]}")
}

# Command implementations
cmd_run() {
    local braid_args=("run")
    
    if [[ -n "$TSI_PROVIDER" ]]; then
        braid_args+=("--provider" "$TSI_PROVIDER")
    fi
    
    if [[ -n "$TSI_MODEL" ]]; then
        braid_args+=("--model" "$TSI_MODEL")
    fi
    
    # Add remaining arguments (prompt, etc.)
    braid_args+=("${TSI_ARGS[@]}")
    
    log_info "Running session with provider=${TSI_PROVIDER:-auto} model=$TSI_MODEL"
    run_braid "${braid_args[@]}"
}

cmd_doctor() {
    log_info "Running environment health checks"
    run_braid doctor
}

cmd_mcp() {
    log_info "Starting MCP server"
    run_braid mcp
}

cmd_build() {
    log_info "Building braid workspace"
    cd "$BRAID_ROOT"
    uv run cargo build --workspace
}

cmd_test() {
    log_info "Running tests"
    cd "$BRAID_ROOT"
    if [[ ${#TSI_ARGS[@]} -gt 0 ]]; then
        uv run cargo test "${TSI_ARGS[@]}"
    else
        uv run cargo test --workspace
    fi
}

cmd_help() {
    usage
}

# Main function
main() {
    # Check if no arguments provided
    if [[ $# -eq 0 ]]; then
        usage
        exit 1
    fi

    # Parse arguments
    parse_args "$@"

    # Check environment
    check_braid_root

    # Handle commands
    case "$TSI_CMD" in
        run)
            cmd_run
            ;;
        doctor)
            cmd_doctor
            ;;
        mcp)
            cmd_mcp
            ;;
        build)
            cmd_build
            ;;
        test)
            cmd_test
            ;;
        help|"")
            cmd_help
            ;;
        *)
            log_error "Unknown command: $TSI_CMD"
            log_error "Run 'tsi help' for usage information"
            exit 1
            ;;
    esac
}

# Run main function with all arguments
main "$@"